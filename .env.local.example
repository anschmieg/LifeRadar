# Copy to .env.local for the self-contained local Matrix test harness.

COMPOSE_PROJECT_NAME=liferadar-local

LIFERADAR_DB_NAME=life_radar
LIFERADAR_DB_USER=life_radar
LIFERADAR_DB_PASSWORD=localdev-password
LIFERADAR_DB_LOCAL_PORT=15432

LIFERADAR_API_KEY=localdev-shared-secret
LIFERADAR_API_PORT=18000
LIFERADAR_MCP_PORT=18090
LIFERADAR_MATRIX_BRIDGE_PORT=18010
LIFERADAR_CHAT_GATEWAY_PORT_PUBLIC=18020

LIFERADAR_MATRIX_ENABLED=true
LIFERADAR_MATRIX_HOMESERVER_URL=
LIFERADAR_MATRIX_RUST_CANDIDATE_ID=matrix-rust-sdk
LIFERADAR_MATRIX_RUST_CANDIDATE_TYPE=matrix-native
LIFERADAR_MATRIX_RUST_TIMEOUT_SEC=20
LIFERADAR_MATRIX_RUST_RECOVER_HTTP_ON_FAILURE=0
LIFERADAR_MATRIX_KEY_IMPORT_ENABLED=false
LIFERADAR_MATRIX_LEGACY_IMPORT_ENABLED=false
MATRIX_RECOVERY_KEY_PATH=
MATRIX_RECOVERY_PASSPHRASE_PATH=./data/identity/.e2e-keys-passphrase
MATRIX_SECRETS_BUNDLE_PATH=./data/identity/matrix-secrets-bundle.json

LIFERADAR_MSGRAPH_ENABLED=false
LIFERADAR_GOOGLE_CALENDAR_ENABLED=false
OUTLOOK_MCP_ENABLED=false

LIFERADAR_TELEGRAM_ENABLED=false
LIFERADAR_WHATSAPP_ENABLED=false
LIFERADAR_WHATSAPP_UNOFFICIAL_ALLOWED=false
LIFERADAR_CONNECTOR_BACKFILL_LIMIT_PER_CHAT=2000

MSGRAPH_CLIENT_ID=
MSGRAPH_CLIENT_SECRET=
MSGRAPH_TENANT_ID=common
MSGRAPH_REFRESH_TOKEN=

GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Optional smoke-test overrides.
LIFERADAR_MATRIX_SMOKE_CONVERSATION_ID=
LIFERADAR_MATRIX_SMOKE_ROOM_ID=
