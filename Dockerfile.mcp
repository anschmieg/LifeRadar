# syntax=docker/dockerfile:1.7

# LifeRadar MCP Server — Python MCP server with Outlook (Softeria) pass-through
FROM python:3.12-slim-bookworm AS builder

WORKDIR /app

ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_DEFAULT_TIMEOUT=120 \
    VIRTUAL_ENV=/opt/venv \
    PATH=/opt/venv/bin:$PATH

RUN python -m venv "$VIRTUAL_ENV"

COPY mcp-server/requirements.txt ./requirements.txt
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-compile -r requirements.txt

COPY mcp-server/ ./mcp-server/

FROM python:3.12-slim-bookworm

WORKDIR /app

ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    VIRTUAL_ENV=/opt/venv \
    PATH=/opt/venv/bin:/usr/local/bin:$PATH

COPY --from=builder /opt/venv /opt/venv
COPY --from=builder /app/mcp-server/ ./mcp-server/

# Install Node.js for Softeria MS-365 MCP subprocess
# npx -y auto-upgrades to the latest version on each call
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl && \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Pre-cache Softeria MCP for faster startup (npx -y will still check for upgrades)
RUN npm install -g @softeria/ms-365-mcp-server || true

# Token cache directory for Softeria auth (persisted via Docker volume)
RUN mkdir -p /app/outlook-token-cache && chmod 700 /app/outlook-token-cache

ENV PYTHONUNBUFFERED=1
ENV LIFE_RADAR_API_URL=http://host.docker.internal:8000
ENV OUTLOOK_MCP_ENABLED=false
ENV MS365_MCP_TOKEN_CACHE_PATH=/app/outlook-token-cache/.token-cache.json
ENV MS365_MCP_SELECTED_ACCOUNT_PATH=/app/outlook-token-cache/.selected-account.json

CMD ["python", "mcp-server/server.py"]