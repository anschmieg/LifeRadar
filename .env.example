# LifeRadar — Environment Variables
# Copy to .env and fill in your values

# === Database ===
# LOCAL DEV: Use 127.0.0.1 with SSH tunnel (ssh -N -L 127.0.0.1:5432:10.0.2.12:5432 oracle)
# COOLIFY: Use 10.0.2.12 (Oracle container IP on Docker network)
LIFERADAR_DB_HOST=127.0.0.1
LIFERADAR_DB_PORT=5432
LIFERADAR_DB_NAME=life_radar
LIFERADAR_DB_USER=life_radar
LIFERADAR_DB_PASSWORD=your-db-password-here

# === API ===
LIFERADAR_API_KEY=generate-a-random-shared-secret

# === Direct messaging connectors ===
LIFERADAR_MATRIX_ENABLED=true
LIFERADAR_MATRIX_HOMESERVER_URL=https://matrix.beeper.com
LIFERADAR_TELEGRAM_ENABLED=true
LIFERADAR_WHATSAPP_ENABLED=true
LIFERADAR_WHATSAPP_UNOFFICIAL_ALLOWED=true
LIFE_RADAR_CHAT_GATEWAY_URL=http://liferadar-chat-gateway:8020
LIFERADAR_CONNECTOR_SESSION_DIR=/app/connectors
# Host bind paths used by docker-compose driver_opts:
# /data/liferadar/connectors
# /data/liferadar/outlook-token-cache
# Telegram personal account credentials from https://my.telegram.org
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# Optional WhatsApp connection tuning
# LIFERADAR_CONNECTOR_BACKFILL_LIMIT_PER_CHAT=5000

# Matrix session and identity
MATRIX_SESSION_PATH=/data/liferadar/identity/matrix-session.json
MATRIX_RUST_SESSION_PATH=/data/liferadar/identity/matrix-session.json
MATRIX_RUST_STORE=/data/liferadar/identity/matrix-rust-sdk-store

# Room key export (Beeper Desktop format, or any Matrix client Megolm export)
MATRIX_ROOM_KEYS_PATH=/data/liferadar/identity/matrix-e2e-keys.txt
MATRIX_ROOM_KEYS_PASSPHRASE_PATH=/data/liferadar/identity/.e2e-keys-passphrase
MATRIX_RUST_KEY_IMPORT_MARKER=/data/liferadar/identity/matrix-rust-sdk-store/room-key-import-marker.json
LIFERADAR_MATRIX_BRIDGE_URL=http://liferadar-matrix-bridge:8010

# === Optional: MSGraph (Outlook) ===
# MSGRAPH_CLIENT_ID=
# MSGRAPH_CLIENT_SECRET=
# MSGRAPH_TENANT_ID=
# MSGRAPH_REFRESH_TOKEN=

# === Optional: Outlook MCP (Softeria MS-365) ===
# Dynamically exposes all Softeria mail tools as outlook-* tools in the LifeRadar MCP.
# Tools include outlook-send-mail, outlook-list-mail-messages, outlook-reply-mail-message,
# outlook-get-mail-message, outlook-list-mail-folders, outlook-create-draft-email, etc.
# The Softeria MS-365 MCP server runs as a subprocess inside the life-radar-mcp container.
# On first use, authenticate via login-outlook (device code flow will show a URL and code).
# Reuses the MSGraph Azure AD app credentials above for authentication.
# OUTLOOK_MCP_ENABLED=true

# === Optional: Google Calendar ===
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# === Optional: Tuning ===
LIFE_RADAR_PROBE_INTERVAL_SEC=300
LIFERADAR_MATRIX_RUST_CANDIDATE_ID=matrix-rust-sdk
LIFERADAR_MATRIX_RUST_CANDIDATE_TYPE=matrix-native
LIFERADAR_MATRIX_RUST_TIMEOUT_SEC=20
LIFERADAR_MATRIX_RUST_RECOVER_HTTP_ON_FAILURE=0
# Internal send bridge URL used by the API service
# LIFERADAR_MATRIX_BRIDGE_URL=http://liferadar-matrix-bridge:8010
