# LifeRadar — Environment Variables
# Copy to .env and fill in your values

# === Required ===

LIFE_RADAR_DB_NAME=life_radar
LIFE_RADAR_DB_USER=life_radar
LIFE_RADAR_DB_PASSWORD=your-db-password-here
# Optional shared secret for write endpoints and MCP proxy
# LIFE_RADAR_API_KEY=generate-a-random-shared-secret

# Matrix/Beeper session (copy from OpenClaw data mount)
MATRIX_SESSION_PATH=/data/openclaw/config/.openclaw/identity/matrix-session.json
MATRIX_RUST_SESSION_PATH=/data/openclaw/config/.openclaw/identity/matrix-session.json
MATRIX_RUST_STORE=/data/openclaw/config/.openclaw/identity/matrix-rust-sdk-store
MATRIX_E2EE_EXPORT_PATH=/data/openclaw/config/.openclaw/identity/beeper-e2e-keys.txt
MATRIX_E2EE_EXPORT_PASSPHRASE_PATH=/data/openclaw/config/.openclaw/identity/.e2ee-export-passphrase
MATRIX_RUST_KEY_IMPORT_MARKER=/data/openclaw/config/.openclaw/identity/matrix-rust-sdk-store/room-key-import-marker.json
LIFE_RADAR_MATRIX_BRIDGE_URL=http://life-radar-matrix-bridge:8010

# === Optional: MSGraph (Outlook) ===
# MSGRAPH_CLIENT_ID=
# MSGRAPH_CLIENT_SECRET=
# MSGRAPH_TENANT_ID=
# MSGRAPH_REFRESH_TOKEN=

# === Optional: Outlook MCP (Softeria MS-365) ===
# Dynamically exposes all Softeria mail tools as outlook-* tools in the LifeRadar MCP.
# Tools include outlook-send-mail, outlook-list-mail-messages, outlook-reply-mail-message,
# outlook-get-mail-message, outlook-list-mail-folders, outlook-create-draft-email, etc.
# The Softeria MS-365 MCP server runs as a subprocess inside the life-radar-mcp container.
# On first use, authenticate via login-outlook (device code flow will show a URL and code).
# Reuses the MSGraph Azure AD app credentials above for authentication.
# OUTLOOK_MCP_ENABLED=true

# === Optional: Google Calendar ===
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# === Optional: Tuning ===
LIFE_RADAR_PROBE_INTERVAL_SEC=300
LIFE_RADAR_MATRIX_RUST_CANDIDATE_ID=matrix-rust-sdk
LIFE_RADAR_MATRIX_RUST_CANDIDATE_TYPE=matrix-native
LIFE_RADAR_MATRIX_RUST_TIMEOUT_SEC=20
LIFE_RADAR_MATRIX_RUST_RECOVER_HTTP_ON_FAILURE=0
# Internal send bridge URL used by the API service
# LIFE_RADAR_MATRIX_BRIDGE_URL=http://life-radar-matrix-bridge:8010
