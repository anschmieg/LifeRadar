FROM debian:bookworm-slim

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    ca-certificates \
    curl \
    dbus \
    dbus-x11 \
    desktop-file-utils \
    fluxbox \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libc6 \
    libcairo2 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libglib2.0-0 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libpango-1.0-0 \
    libu2f-udev \
    libx11-6 \
    libx11-xcb1 \
    libxcb-dri3-0 \
    libxcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxkbcommon0 \
    libxrandr2 \
    novnc \
    websockify \
    x11-apps \
    x11-utils \
    xdg-utils \
    xterm \
    x11vnc \
    xvfb \
    zlib1g-dev \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /opt/beeper /data/beeper-home /run/dbus /tmp/.X11-unix
RUN dbus-daemon --system --fork >/tmp/dbus-system.log 2>&1 || true

# Use existing pre-built entrypoint if available, otherwise minimal entrypoint
COPY bin/beeper-sidecar-entrypoint.sh /usr/local/bin/beeper-sidecar-entrypoint.sh
COPY bin/beeper-sidecar-proxy.py /usr/local/bin/beeper-sidecar-proxy.py

# Minimal entrypoint that just starts the proxy
ENTRYPOINT ["python3", "/usr/local/bin/beeper-sidecar-proxy.py"]
