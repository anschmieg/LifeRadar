# syntax=docker/dockerfile:1.7

# ============================================================
# LifeRadar Worker
# Node.js probe orchestrator + Rust E2EE Matrix probe
# ============================================================

# ---- Stage 1: Rust dependency planner ----
FROM lukemathwalker/cargo-chef:latest-rust-1.88-bookworm AS cargo-chef

WORKDIR /build

# ---- Stage 2: Rust dependency recipe ----
FROM cargo-chef AS planner
WORKDIR /build/matrix-rust-probe
COPY matrix-rust-probe/Cargo.toml ./Cargo.toml
COPY matrix-rust-probe/Cargo.lock ./Cargo.lock
COPY matrix-rust-probe/src ./src
RUN cargo chef prepare --recipe-path /build/recipe.json --bin life-radar-matrix-rust-probe

# ---- Stage 3: Rust build ----
FROM cargo-chef AS rust-build

ARG TARGETARCH=amd64

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    pkg-config \
    libssl-dev \
    libsqlite3-dev \
    libsasl2-dev \
    cmake \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY --from=planner /build/recipe.json recipe.json
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/build/target,sharing=locked \
    cargo chef cook --release --recipe-path recipe.json --target-dir /build/target

COPY matrix-rust-probe/ ./probe/

RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/build/target,sharing=locked <<EOF
    cargo build --release --bin life-radar-matrix-rust-probe --manifest-path /build/probe/Cargo.toml --target-dir /build/target 2>&1
    cp /build/target/release/life-radar-matrix-rust-probe /build/life-radar-matrix-rust-probe
EOF

RUN strip /build/life-radar-matrix-rust-probe 2>/dev/null || true


# ---- Stage 2: Node.js runtime ----
FROM node:22-bookworm-slim

ARG TARGETARCH=amd64

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
    postgresql-client \
    ca-certificates \
    jq \
    libsqlite3-0 \
    sqlite3 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy the pre-built Rust binary from Stage 1
COPY --from=rust-build /build/life-radar-matrix-rust-probe /usr/local/bin/life-radar-matrix-rust-probe

# Copy probe scripts (entrypoint is run-probes.sh)
COPY bin/ /opt/life-radar/bin/

# Copy lib/ for Node.js runtime modules (runtime.mjs, etc.)
COPY lib/ /opt/life-radar/lib/

# Copy schema for bootstrap
COPY schema/schema.sql /opt/life-radar/schema.sql

RUN chmod +x /usr/local/bin/life-radar-matrix-rust-probe \
 && chmod +x /opt/life-radar/bin/*.sh \
 && chmod +x /opt/life-radar/bin/*.mjs

# Identity + workspace volumes (bind-mounted at runtime)
VOLUME ["/app/identity", "/app/workspace"]

ENTRYPOINT ["/opt/life-radar/bin/run-probes.sh"]
