#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
LOCAL_BIN="${ROOT_DIR}/.local/bin"

# Default to inline Rich output. Use --tui flag for fullscreen TUI.
if [[ "$*" == *"--tui"* ]]; then
    exec python3 "${LOCAL_BIN}/nextcloud_legacy_compare_tui.py" "$@"
else
    exec python3 "${LOCAL_BIN}/nextcloud_legacy_compare_status.py" "$@"
fi
